---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Snipstack — Coming Soon" description="Privacy & streaming tools that actually work.">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
      color: #e2e8f0;
    }

    main {
      text-align: center;
      padding: 2rem;
      max-width: 640px;
    }

    .badge {
      display: inline-block;
      background: rgba(99, 179, 237, 0.12);
      border: 1px solid rgba(99, 179, 237, 0.3);
      color: #63b3ed;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border-radius: 100px;
      margin-bottom: 1.75rem;
    }

    h1 {
      font-size: clamp(2rem, 6vw, 3.25rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      line-height: 1.1;
      margin-bottom: 1.25rem;
      background: linear-gradient(135deg, #e2e8f0 0%, #63b3ed 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .tagline {
      font-size: 1.125rem;
      color: #94a3b8;
      line-height: 1.6;
    }

    footer {
      position: fixed;
      bottom: 1.5rem;
      font-size: 0.8rem;
      color: #475569;
    }
  </style>

  <main>
    <div class="badge">Coming Soon</div>
    <h1>Snipstack</h1>
    <p class="tagline">Privacy &amp; streaming tools that actually work.</p>
  </main>

  <footer>
    &copy; 2026 Snipstack
  </footer>
</Layout>
