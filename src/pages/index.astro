---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const CATEGORIES = [
  { slug: 'vpn',           label: 'VPN & Streaming',       tags: ['vpn'],                  icon: '🔒' },
  { slug: 'adblock',       label: 'Ad Blockers',            tags: ['adblock', 'ad blocker'], icon: '🛡️' },
  { slug: 'antivirus',     label: 'Antivirus & Security',   tags: ['antivirus', 'one'],      icon: '🦠' },
  { slug: 'phone-privacy', label: 'Phone Privacy',          tags: ['altnumber'],             icon: '📱' },
  { slug: 'email-privacy', label: 'Email Privacy',          tags: ['altid'],                 icon: '✉️' },
];

const categorized = CATEGORIES.map(cat => ({
  ...cat,
  total: allPosts.filter(p => p.data.tags.some(t => cat.tags.includes(t))).length,
  posts: allPosts.filter(p => p.data.tags.some(t => cat.tags.includes(t))).slice(0, 4),
})).filter(c => c.posts.length > 0);
---

<Layout title="Snipstack — Privacy & Streaming Tools That Actually Work" description="Independent reviews and comparisons for VPNs, ad blockers, and privacy tools. No fluff. Just what works.">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Istok Web', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1f2937;
      line-height: 1.6;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #0e3655;
    }

    .site-header {
      background: #ffffff;
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .logo {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: #0e3655;
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .logo span { color: #22d3ee; }

    .nav {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
    }

    .nav a {
      color: #6b7280;
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      transition: color 0.15s;
    }

    .nav a:hover { color: #22d3ee; }

    .hero {
      background: linear-gradient(135deg, #06b6d4 0%, #22d3ee 50%, #67e8f9 100%);
      padding: 5rem 1.5rem;
      text-align: center;
      color: #ffffff;
    }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      color: #ffffff;
      max-width: 720px;
      margin: 0 auto 1rem;
      line-height: 1.15;
    }

    .hero p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.95);
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    .hero-cta {
      display: inline-block;
      background: #ffffff;
      color: #0e3655;
      font-weight: 700;
      padding: 0.9rem 2rem;
      border-radius: 4px;
      text-decoration: none;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
      transition: transform 0.15s, box-shadow 0.15s;
    }

    .hero-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 15px -3px rgba(0,0,0,0.15);
    }

    /* Category section */
    .cat-section {
      padding: 3.5rem 1.5rem;
      border-bottom: 1px solid #f1f5f9;
    }

    .cat-section:nth-child(even) { background: #f8fafc; }

    .cat-section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .cat-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .cat-title-group {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .cat-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #ef4444;
    }

    .cat-title {
      font-size: 1.5rem;
      color: #0e3655;
    }

    .cat-see-all {
      font-size: 0.85rem;
      font-weight: 700;
      color: #06b6d4;
      text-decoration: none;
      white-space: nowrap;
      border: 1.5px solid #06b6d4;
      padding: 0.35rem 0.9rem;
      border-radius: 4px;
      transition: background 0.15s, color 0.15s;
    }

    .cat-see-all:hover {
      background: #06b6d4;
      color: #ffffff;
    }

    .article-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }

    .article-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      overflow: hidden;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      position: relative;
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    }

    .article-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 20px -5px rgba(0,0,0,0.1);
      border-color: #22d3ee;
    }

    .editors-pick-badge {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: #ef4444;
      color: white;
      font-size: 0.65rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      padding: 0.25rem 0.6rem;
      border-radius: 100px;
      text-transform: uppercase;
      z-index: 2;
      box-shadow: 0 2px 4px rgba(239,68,68,0.3);
    }

    .card-image {
      width: 100%;
      aspect-ratio: 1200/630;
      object-fit: cover;
      background: #f1f5f9;
    }

    .card-body {
      padding: 1.1rem 1.25rem 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .card-tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 0.6rem;
    }

    .card-tag {
      background: #ecfeff;
      color: #06b6d4;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0.1rem 0.5rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 700;
      color: #0e3655;
      line-height: 1.35;
      margin-bottom: 0.5rem;
    }

    .card-desc {
      font-size: 0.85rem;
      color: #6b7280;
      line-height: 1.5;
      margin-bottom: 0.75rem;
      flex: 1;
    }

    .card-date {
      font-size: 0.75rem;
      color: #9ca3af;
    }

    footer {
      background: #0e3655;
      color: #cbd5e1;
      padding: 3rem 1.5rem;
      text-align: center;
    }

    footer .footer-inner { max-width: 720px; margin: 0 auto; }

    footer .footer-logo {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.2rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 0.5rem;
    }

    footer .footer-logo span { color: #22d3ee; }

    footer .footer-tagline {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.7);
      margin-bottom: 1.5rem;
    }

    footer .footer-disclosure {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.5;
      max-width: 580px;
      margin: 0 auto;
    }
  </style>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Snip<span>stack</span></a>
      <nav class="nav">
        <a href="/category/vpn/">VPN</a>
        <a href="/category/adblock/">Ad Blockers</a>
        <a href="/category/antivirus/">Antivirus</a>
        <a href="/category/phone-privacy/">Phone Privacy</a>
        <a href="/category/email-privacy/">Email Privacy</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <h1>Privacy tools that actually work</h1>
    <p>Independent reviews of VPNs, ad blockers, and second phone numbers. No fluff. No paid placement bias. Just what we tested.</p>
    <a href="#categories" class="hero-cta">Browse Reviews →</a>
  </section>

  <div id="categories">
    {categorized.map((cat, catIdx) => (
      <section class="cat-section">
        <div class="cat-section-inner">
          <div class="cat-header">
            <div class="cat-title-group">
              <span class="cat-label">{cat.icon} {cat.label}</span>
              <h2 class="cat-title">{cat.label} Reviews</h2>
            </div>
            {cat.total > 4 && (
              <a href={`/category/${cat.slug}/`} class="cat-see-all">
                See all {cat.total} reviews →
              </a>
            )}
          </div>

          <div class="article-grid">
            {cat.posts.map((post, idx) => (
              <a href={`/${post.id}/`} class="article-card">
                {catIdx === 0 && idx === 0 && <span class="editors-pick-badge">⭐ Editor's Pick</span>}
                {post.data.heroImage && (
                  <img src={post.data.heroImage} alt={post.data.title} class="card-image" loading="lazy" />
                )}
                <div class="card-body">
                  <div class="card-tags">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="card-tag">{tag}</span>
                    ))}
                  </div>
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-desc">{post.data.description}</p>
                  <time class="card-date" datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Snip<span>stack</span></div>
      <p class="footer-tagline">Privacy & streaming tools that actually work.</p>
      <p class="footer-disclosure">
        © 2026 Snipstack · Independent product reviews · Affiliate disclosure: this site may earn a commission when you purchase through links on our pages. We only recommend products we've tested.
      </p>
    </div>
  </footer>
</Layout>
