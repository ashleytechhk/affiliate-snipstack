---
export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Privacy & streaming tools that actually work.',
  canonicalURL = Astro.url.href,
  ogImage = '/og-default.png',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG / Social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Montserrat (heading) + Istok Web (body) — Ashley Tech-inspired typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Istok+Web:wght@400;700&display=swap" />

    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NT7MLPX9FE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NT7MLPX9FE');
    </script>

    <!-- Affiliate click tracking: fire GA4 event before cloaker redirect -->
    <script is:inline>
      document.addEventListener('click', function(e) {
        var a = e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        // Match all snipstack cloaker paths
        if (!/^\/(blog|go|sk|vp|ab|pn|id|av)(\/|$|\?)/.test(href)) return;
        try {
          var url = new URL(href, location.origin);
          var parts = url.pathname.replace(/^\//, '').split('/');
          var product = parts[1] || parts[0] || 'unknown';
          var sub = url.searchParams.get('sub') || '';
          gtag('event', 'affiliate_click', {
            product: product,
            sub_id: sub,
            link_url: href,
            transport_type: 'beacon',
          });
        } catch(err) {}
      });
    </script>

    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
