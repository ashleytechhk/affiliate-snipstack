---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  heroImage?: string;
  tags?: string[];
  slug: string;
  toc?: Array<{ depth: number; slug: string; text: string }>;
  prev?: any;
  next?: any;
  related?: any[];
}

const { title, description, publishDate, heroImage, tags = [], slug, toc = [], prev, next, related = [] } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate.toISOString(),
  "author": { "@type": "Organization", "name": "Snipstack" },
  "publisher": {
    "@type": "Organization",
    "name": "Snipstack",
    "url": "https://snipstack.io"
  },
  "url": `https://snipstack.io/${slug}/`,
  "image": heroImage ? `https://snipstack.io${heroImage}` : undefined
});
---

<Layout title={title} description={description} ogImage={heroImage ?? '/og-default.png'}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Istok Web', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1f2937;
      margin: 0;
      padding: 0;
      line-height: 1.7;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #0e3655;
    }

    /* Header */
    .site-header {
      background: #ffffff;
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: #0e3655;
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .logo span { color: #22d3ee; }

    .nav { display: flex; gap: 1.75rem; }
    .nav a {
      color: #6b7280;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .nav a:hover { color: #22d3ee; }

    /* 3-column grid layout */
    .article-grid {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 3rem;
      padding: 2.5rem 1.5rem 4rem;
    }

    .article-main {
      max-width: 760px;
      min-width: 0;
    }

    /* Right sidebar - sticky TOC */
    .article-toc {
      position: sticky;
      top: 5rem;
      align-self: start;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
      font-size: 0.85rem;
    }

    .toc-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #ef4444;
      margin-bottom: 0.75rem;
      padding-left: 0.6rem;
      border-left: 3px solid #ef4444;
    }

    .toc-list { list-style: none; padding: 0; margin: 0; }

    .toc-list li {
      margin: 0;
    }

    .toc-list a {
      display: block;
      padding: 0.4rem 0.75rem;
      color: #6b7280;
      text-decoration: none;
      border-left: 2px solid #e5e7eb;
      transition: all 0.15s;
      font-size: 0.85rem;
      line-height: 1.4;
    }

    .toc-list a:hover {
      color: #06b6d4;
      border-left-color: #22d3ee;
      background: #f0fdfa;
    }

    .toc-list a.depth-3 {
      padding-left: 1.5rem;
      font-size: 0.8rem;
      color: #94a3b8;
    }

    /* Article content */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #6b7280;
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.15s;
    }

    .back-link:hover { color: #22d3ee; }

    .meta {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .meta time {
      color: #9ca3af;
      font-size: 0.875rem;
    }

    .tag {
      background: #ecfeff;
      color: #06b6d4;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.15rem 0.55rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    h1.article-title {
      font-size: clamp(1.85rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      margin: 0 0 1.5rem;
      color: #0e3655;
    }

    .hero-img {
      width: 100%;
      border-radius: 12px;
      margin-bottom: 2rem;
      aspect-ratio: 1200/630;
      object-fit: cover;
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
    }

    /* Prev/Next nav */
    .article-nav {
      max-width: 1280px;
      margin: 3rem auto 2rem;
      padding: 0 1.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .article-nav a {
      display: block;
      padding: 1rem 1.25rem;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      text-decoration: none;
      transition: all 0.15s;
      background: #ffffff;
    }

    .article-nav a:hover {
      border-color: #22d3ee;
      box-shadow: 0 4px 12px rgba(14, 54, 85, 0.08);
      transform: translateY(-2px);
    }

    .article-nav .nav-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #ef4444;
      margin-bottom: 0.4rem;
    }

    .article-nav .nav-title {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      color: #0e3655;
      font-size: 0.95rem;
      line-height: 1.3;
    }

    .article-nav .nav-next {
      text-align: right;
    }

    .article-nav .nav-empty {
      visibility: hidden;
    }

    /* Related articles section */
    .related-section {
      max-width: 1280px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .related-label {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #ef4444;
      text-align: center;
      margin-bottom: 0.5rem;
    }

    .related-title {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.5rem;
      text-align: center;
      color: #0e3655;
      margin-bottom: 0.5rem;
    }

    .related-divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, #ef4444 0%, #22d3ee 100%);
      margin: 0.75rem auto 2rem;
      border-radius: 2px;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.25rem;
    }

    .related-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      overflow: hidden;
      text-decoration: none;
      transition: all 0.15s;
    }

    .related-card:hover {
      border-color: #22d3ee;
      box-shadow: 0 8px 16px -4px rgba(14, 54, 85, 0.08);
      transform: translateY(-2px);
    }

    .related-card-img {
      width: 100%;
      aspect-ratio: 1200/630;
      object-fit: cover;
      background: #f1f5f9;
    }

    .related-card-body {
      padding: 1rem 1.1rem 1.25rem;
    }

    .related-card-title {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      color: #0e3655;
      line-height: 1.35;
    }

    /* Footer */
    footer {
      background: #0e3655;
      color: #cbd5e1;
      padding: 3rem 1.5rem;
      text-align: center;
    }

    footer .footer-inner {
      max-width: 720px;
      margin: 0 auto;
    }

    footer .footer-logo {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.2rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 0.5rem;
    }

    footer .footer-logo span { color: #22d3ee; }

    footer .footer-links {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      margin: 1rem 0;
      flex-wrap: wrap;
    }

    footer .footer-links a {
      color: rgba(255,255,255,0.7);
      font-size: 0.85rem;
      text-decoration: none;
    }

    footer .footer-links a:hover { color: #22d3ee; }

    footer .footer-disclosure {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.5;
      max-width: 580px;
      margin: 0 auto;
    }

    /* Mobile responsive */
    @media (max-width: 980px) {
      .article-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .article-toc {
        position: static;
        max-height: none;
        order: -1;
        background: #f8fafc;
        padding: 1rem;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
      }
      .article-nav {
        grid-template-columns: 1fr;
      }
      .article-nav .nav-next {
        text-align: left;
      }
    }
  </style>

  <!-- Global styles for markdown-rendered slot content (Astro scoping bypass) -->
  <style is:global>
    /* Article body typography */
    .prose {
      line-height: 1.75;
      color: #1f2937;
      font-size: 1.05rem;
    }
    .prose h2 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: #0e3655;
      margin: 3rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #ecfeff;
      scroll-margin-top: 5rem;
    }
    .prose h3 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: #0e3655;
      margin: 2rem 0 0.75rem;
      scroll-margin-top: 5rem;
    }
    .prose h4 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: #0e3655;
      margin: 1.5rem 0 0.5rem;
    }
    .prose p { margin: 0 0 1.25rem; }
    .prose ul, .prose ol { margin: 0 0 1.25rem 1.5rem; }
    .prose li { margin-bottom: 0.5rem; }

    .prose a {
      color: #06b6d4;
      text-decoration: underline;
      text-decoration-color: rgba(6, 182, 212, 0.4);
      font-weight: 600;
    }
    .prose a:hover { text-decoration-color: #06b6d4; }
    .prose strong { color: #0e3655; font-weight: 700; }

    /* In-content images — constrain to article width */
    .prose img {
      max-width: 100%;
      width: 100%;
      height: auto;
      display: block;
      margin: 2.5rem auto;
      border-radius: 12px;
      box-shadow: 0 4px 12px rgba(14, 54, 85, 0.08);
    }

    /* Image caption (italic em right after image paragraph) */
    .prose p > em:only-child {
      display: block;
      text-align: center;
      font-size: 0.88rem;
      color: #6b7280;
      margin-top: -1.5rem;
      margin-bottom: 2.5rem;
    }

    /* Premium comparison table */
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-size: 0.9rem;
      box-shadow: 0 4px 12px rgba(14, 54, 85, 0.1);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }
    .prose thead {
      background: linear-gradient(135deg, #0e3655 0%, #1e5a8e 100%);
    }
    .prose th {
      padding: 1rem 1.1rem;
      text-align: left;
      font-weight: 700;
      color: #ffffff;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      border-bottom: 3px solid #22d3ee;
    }
    .prose td {
      padding: 0.85rem 1.1rem;
      border-bottom: 1px solid #f1f5f9;
      vertical-align: middle;
    }
    .prose tbody tr:nth-child(even) td {
      background: #f8fafc;
    }
    .prose tbody tr:first-child td {
      background: linear-gradient(90deg, #ecfeff 0%, #f0fdfa 100%);
      font-weight: 600;
      color: #0e3655;
      border-bottom: 2px solid #06b6d4;
    }
    .prose tbody tr:first-child td:first-child::before {
      content: "⭐ ";
      color: #ef4444;
      margin-right: 0.2em;
    }
    .prose tbody tr:hover td {
      background: #ecfeff !important;
    }

    /* CTA blockquote */
    .prose blockquote {
      background: linear-gradient(135deg, #ecfeff 0%, #f0fdfa 100%);
      border: 1px solid #67e8f9;
      border-left: 4px solid #06b6d4;
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      margin: 1.75rem 0;
      color: #0e3655;
    }
    .prose blockquote p { margin: 0; }
    .prose blockquote a {
      font-weight: 700;
      text-decoration: none;
      color: #06b6d4;
    }
    .prose blockquote a:hover { color: #0891b2; }

    .prose hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 2.5rem 0;
    }

    .prose code {
      background: #f1f5f9;
      padding: 0.15em 0.4em;
      border-radius: 4px;
      font-size: 0.875em;
      color: #0891b2;
    }

    /* Mobile responsive table */
    @media (max-width: 720px) {
      .prose table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }
  </style>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Snip<span>stack</span></a>
      <nav class="nav">
        <a href="/">Reviews</a>
      </nav>
    </div>
  </header>

  <article class="article-grid">
    <div class="article-main">
      <a href="/" class="back-link">← All articles</a>

      <div class="meta">
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>

      <h1 class="article-title">{title}</h1>

      {heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="hero-img"
          width="1200"
          height="630"
          loading="eager"
        />
      )}

      <div class="prose">
        <slot />
      </div>
    </div>

    {toc.length > 0 && (
      <aside class="article-toc">
        <div class="toc-label">On this page</div>
        <ul class="toc-list">
          {toc.map(h => (
            <li>
              <a href={`#${h.slug}`} class={`depth-${h.depth}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  {(prev || next) && (
    <nav class="article-nav" aria-label="Article navigation">
      {prev ? (
        <a href={`/${prev.id}/`} class="nav-prev">
          <div class="nav-label">← Previous</div>
          <div class="nav-title">{prev.data.title}</div>
        </a>
      ) : <span class="nav-empty"></span>}
      {next ? (
        <a href={`/${next.id}/`} class="nav-next">
          <div class="nav-label">Next →</div>
          <div class="nav-title">{next.data.title}</div>
        </a>
      ) : <span class="nav-empty"></span>}
    </nav>
  )}

  {related.length > 0 && (
    <section class="related-section">
      <p class="related-label">Related Reviews</p>
      <h2 class="related-title">More from Snipstack</h2>
      <div class="related-divider"></div>
      <div class="related-grid">
        {related.map(p => (
          <a href={`/${p.id}/`} class="related-card">
            {p.data.heroImage && (
              <img src={p.data.heroImage} alt={p.data.title} class="related-card-img" loading="lazy" />
            )}
            <div class="related-card-body">
              <div class="related-card-title">{p.data.title}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Snip<span>stack</span></div>
      <div class="footer-links">
        <a href="/">Reviews</a>
        <a href="/">Privacy Policy</a>
        <a href="/">Terms</a>
        <a href="/">Affiliate Disclosure</a>
      </div>
      <p class="footer-disclosure">
        © 2026 Snipstack · Independent product reviews · This site may earn a commission when you purchase through links on our pages. We only recommend products we've tested.
      </p>
    </div>
  </footer>
</Layout>
