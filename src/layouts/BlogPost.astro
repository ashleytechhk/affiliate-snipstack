---
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  heroImage?: string;
  tags?: string[];
  slug: string;
}

const { title, description, publishDate, heroImage, tags = [], slug } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": publishDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Snipstack"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Snipstack",
    "url": "https://snipstack.io"
  },
  "url": `https://snipstack.io/${slug}/`,
  "image": heroImage ? `https://snipstack.io${heroImage}` : undefined
});
---

<Layout title={title} description={description} ogImage={heroImage ?? '/og-default.png'}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Istok Web', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1f2937;
      margin: 0;
      padding: 0;
      line-height: 1.7;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #0e3655;
    }

    /* Header */
    .site-header {
      background: #ffffff;
      border-bottom: 1px solid #e5e7eb;
      padding: 1rem 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: #0e3655;
      text-decoration: none;
      letter-spacing: -0.02em;
    }

    .logo span {
      color: #22d3ee;
    }

    .nav {
      display: flex;
      gap: 1.75rem;
    }

    .nav a {
      color: #6b7280;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .nav a:hover {
      color: #22d3ee;
    }

    /* Article container */
    .article-container {
      max-width: 760px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #6b7280;
      text-decoration: none;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
      transition: color 0.15s;
    }

    .back-link:hover {
      color: #22d3ee;
    }

    .meta {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 1rem;
    }

    .meta time {
      color: #9ca3af;
      font-size: 0.875rem;
    }

    .tag {
      background: #ecfeff;
      color: #06b6d4;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.15rem 0.55rem;
      border-radius: 100px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    h1.article-title {
      font-size: clamp(1.85rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      margin: 0 0 1.5rem;
      color: #0e3655;
    }

    .hero-img {
      width: 100%;
      border-radius: 12px;
      margin-bottom: 2rem;
      aspect-ratio: 1200/630;
      object-fit: cover;
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
    }

    /* Article content */
    .prose {
      line-height: 1.75;
      color: #1f2937;
      font-size: 1.05rem;
    }

    .prose h2 {
      font-size: 1.6rem;
      font-weight: 700;
      color: #0e3655;
      margin: 3rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #ecfeff;
    }

    .prose h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #0e3655;
      margin: 2rem 0 0.75rem;
    }

    .prose h4 {
      font-size: 1.05rem;
      font-weight: 600;
      color: #0e3655;
      margin: 1.5rem 0 0.5rem;
    }

    .prose p {
      margin: 0 0 1.25rem;
    }

    .prose ul, .prose ol {
      margin: 0 0 1.25rem 1.5rem;
    }

    .prose li {
      margin-bottom: 0.5rem;
    }

    .prose a {
      color: #06b6d4;
      text-decoration: underline;
      text-decoration-color: rgba(6, 182, 212, 0.4);
      font-weight: 600;
    }

    .prose a:hover {
      text-decoration-color: #06b6d4;
    }

    .prose strong {
      color: #0e3655;
      font-weight: 700;
    }

    /* Tables — Premium comparison style */
    .prose .table-wrap {
      margin: 2rem 0;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 12px rgba(14, 54, 85, 0.08);
      border: 1px solid #e5e7eb;
    }

    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-size: 0.92rem;
      box-shadow: 0 4px 12px rgba(14, 54, 85, 0.08);
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }

    .prose thead {
      background: linear-gradient(135deg, #0e3655 0%, #1e5a8e 100%);
    }

    .prose th {
      padding: 1rem 1.1rem;
      text-align: left;
      font-weight: 700;
      color: #ffffff;
      font-family: 'Montserrat', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      white-space: nowrap;
      border-bottom: 3px solid #22d3ee;
    }

    .prose td {
      padding: 0.85rem 1.1rem;
      border-bottom: 1px solid #f1f5f9;
      transition: background 0.15s;
    }

    .prose tr:nth-child(even) td {
      background: #f8fafc;
    }

    .prose tr:first-child td {
      background: linear-gradient(90deg, #ecfeff 0%, #f0fdfa 100%);
      font-weight: 600;
      position: relative;
    }

    .prose tr:first-child td:first-child::before {
      content: "⭐";
      margin-right: 0.4em;
    }

    .prose tr:hover td {
      background: #ecfeff !important;
    }

    /* Auto-style "Yes" / "No" / "Limited" / "High" / "Low" / "Medium" cells */
    .prose td:contains("Yes") { color: #059669; }

    /* Responsive table on mobile — horizontal scroll */
    @media (max-width: 720px) {
      .prose table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
    }

    /* CTA boxes (blockquote) */
    .prose blockquote {
      background: linear-gradient(135deg, #ecfeff 0%, #f0fdfa 100%);
      border: 1px solid #67e8f9;
      border-left: 4px solid #06b6d4;
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin: 1.75rem 0;
      color: #0e3655;
    }

    .prose blockquote p {
      margin: 0;
    }

    .prose blockquote a {
      font-weight: 700;
      text-decoration: none;
      color: #06b6d4;
      background: none;
      -webkit-text-fill-color: #06b6d4;
    }

    .prose blockquote a:hover {
      color: #0891b2;
      -webkit-text-fill-color: #0891b2;
    }

    .prose hr {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 2.5rem 0;
    }

    .prose code {
      background: #f1f5f9;
      padding: 0.15em 0.4em;
      border-radius: 4px;
      font-size: 0.875em;
      color: #0891b2;
    }

    /* Footer */
    footer {
      background: #0e3655;
      color: #cbd5e1;
      padding: 3rem 1.5rem;
      text-align: center;
    }

    footer .footer-inner {
      max-width: 720px;
      margin: 0 auto;
    }

    footer .footer-logo {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.2rem;
      font-weight: 800;
      color: #ffffff;
      margin-bottom: 0.5rem;
    }

    footer .footer-logo span {
      color: #22d3ee;
    }

    footer .footer-disclosure {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.5;
      max-width: 580px;
      margin: 0 auto;
    }
  </style>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Snip<span>stack</span></a>
      <nav class="nav">
        <a href="/">Reviews</a>
      </nav>
    </div>
  </header>

  <article class="article-container">
    <a href="/" class="back-link">← All articles</a>

    <div class="meta">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>

    <h1 class="article-title">{title}</h1>

    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="hero-img"
        width="1200"
        height="630"
        loading="eager"
      />
    )}

    <div class="prose">
      <slot />
    </div>
  </article>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Snip<span>stack</span></div>
      <p class="footer-disclosure">
        © 2026 Snipstack · Independent product reviews · Affiliate disclosure: this site may earn a commission when you purchase through links on our pages. We only recommend products we've tested.
      </p>
    </div>
  </footer>
</Layout>
